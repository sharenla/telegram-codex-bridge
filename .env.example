# Required
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Strongly recommended: comma-separated chat ids (private chat id or group id, groups are usually negative)
TELEGRAM_ALLOWLIST=123456789

# Optional: where to persist telegram offset + per-chat thread config
STORE_PATH=./data/store.json

# Optional Telegram transport:
# Leave TELEGRAM_PROXY_URL empty for direct access.
# If Telegram is flaky on your network, point it to a local Clash/Mihomo mixed-port, e.g. http://127.0.0.1:1082
# Set TELEGRAM_PROXY_URL=direct to force direct mode and skip auto-detection.
TELEGRAM_PROXY_URL=
TELEGRAM_PROXY_AUTO=1
TELEGRAM_POLL_TIMEOUT_SECONDS=5

# Optional Codex upstream proxy:
# Telegram proxy settings do NOT affect Codex. If chatgpt.com is blocked/flaky, set one of these so
# the spawned `codex app-server` inherits it too.
# HTTPS_PROXY=http://127.0.0.1:1082
# ALL_PROXY=socks5h://127.0.0.1:1082

# Optional but recommended:
# Use a dedicated Codex home for Telegram so account swaps don't touch your local GUI session.
CODEX_HOME=./data/codex-home

# Optional desktop parity / source-of-truth alignment:
# DESKTOP_CODEX_HOME points at the Codex GUI home used for comparison in /truth.
# SOURCE_REGISTRY_PATH can point to a JSON file that maps projects to their real repo/runtime/state/log sources.
# Leave SOURCE_REGISTRY_PATH empty to use ./config/source-registry.json when that file exists.
# CODEX_CONTEXT_SYNC copies desktop memories/skills/plugins/rules and a safety-filtered config.toml into CODEX_HOME.
# It does not copy auth.json, sessions, sqlite state, or logs.
CODEX_CONTEXT_SYNC=1
DESKTOP_CODEX_HOME=~/.codex
SOURCE_REGISTRY_PATH=
# Optional when the installed LaunchAgent service copy is not the same as the workspace checkout.
BRIDGE_WORKSPACE_ROOT=

# Optional account pool:
# Leave this empty if you only use one Codex account on this machine.
# If you use OpenClaw, point it to your local auth-profiles.json.
# Multiple files can be comma-separated; the bridge deduplicates accounts and keeps the freshest token.
CODEX_ACCOUNTS_SOURCE=~/.openclaw/agents/main/agent/auth-profiles.json
CODEX_AUTO_ACCOUNT_FAILOVER=1
# Comma-separated email/profileId/accountId values to try only after other usable accounts.
CODEX_LAST_RESORT_ACCOUNTS=

# Optional: route the Codex app-server through local codex-lb.
# Start codex-lb first, then enable this. The bridge writes the official Codex CLI
# provider block into CODEX_HOME/config.toml after desktop context sync.
# CODEX_BACKEND=codex-lb
# CODEX_LB_CODEX_BASE_URL=http://127.0.0.1:2455/backend-api/codex
# CODEX_LB_ENV_KEY=CODEX_LB_API_KEY
# CODEX_LB_API_KEY=

# Codex defaults (per chat)
CODEX_CWD=~
# Telegram /model supports short aliases 5.2 / 5.4 / 5.5, saved internally as gpt-5.x.
CODEX_MODEL=gpt-5.4
# Telegram /effort and /think accept none, minimal, low, medium, high, xhigh.
CODEX_EFFORT=xhigh
# Automatic per-turn model/effort routing: off, suggest, or auto.
CODEX_AUTO_ROUTE=off
CODEX_SUMMARY=concise
CODEX_PERSONALITY=friendly

# Context usage observation / manual compaction
# Phase 1 + 2 only observe usage and enable /compact; auto compaction stays off by default.
AUTO_COMPACT=0
CONTEXT_SOFT_RATIO=0.70
CONTEXT_HARD_RATIO=0.82
CONTEXT_EMERGENCY_RATIO=0.90

# Safer default for remote use:
# - workspace-write: only lets Codex modify files under the chosen workspace/cwd
# - untrusted + AUTO_APPROVE=0: asks in Telegram before risky command/file actions
CODEX_APPROVAL_POLICY=untrusted
CODEX_SANDBOX=workspace-write
AUTO_APPROVE=0

# More hands-off, but still limited to the workspace:
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX=workspace-write
# AUTO_APPROVE=1

# Full machine access (VERY dangerous):
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX=danger-full-access
# AUTO_APPROVE=1
