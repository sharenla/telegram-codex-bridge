# Required
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Strongly recommended: comma-separated chat ids (private chat id or group id, groups are usually negative)
TELEGRAM_ALLOWLIST=123456789

# Optional: where to persist telegram offset + per-chat thread config
STORE_PATH=./data/store.json

# Optional but recommended:
# Use a dedicated Codex home for Telegram so account swaps don't touch your local GUI session.
CODEX_HOME=./data/codex-home

# Optional account pool:
# Leave this empty if you only use one Codex account on this machine.
# If you use OpenClaw, point it to your local auth-profiles.json.
CODEX_ACCOUNTS_SOURCE=~/.openclaw/agents/main/agent/auth-profiles.json
CODEX_AUTO_ACCOUNT_FAILOVER=1

# Codex defaults (per chat)
CODEX_CWD=~
CODEX_MODEL=gpt-5.4
CODEX_EFFORT=xhigh
CODEX_SUMMARY=concise
CODEX_PERSONALITY=friendly

# Highest autonomy (dangerous):
CODEX_APPROVAL_POLICY=untrusted
CODEX_SANDBOX=danger-full-access
AUTO_APPROVE=0

# Fully hands-off (VERY dangerous):
# CODEX_APPROVAL_POLICY=never
# AUTO_APPROVE=1
